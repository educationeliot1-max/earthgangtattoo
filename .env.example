TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
STUDIO_WHATSAPP=whatsapp:+66618042224

# ----- Studio Info -----
NEXT_PUBLIC_STUDIO_PHONE=0618042224
